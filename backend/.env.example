# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://your-api.example.com/webhook
YOUR_CHAT_ID=

# Google Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_REGION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VIDEO_MODEL=gemini-2.5-pro
GEMINI_INLINE_VIDEO_MAX_BYTES=18000000

# Data services
DATABASE_URL=
REDIS_URL=redis://redis:6379/0

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_BUCKET_ID=

# Application security and routing
SECRET_KEY=
DASHBOARD_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5174
SKIP_AUTH=true

# Local PostgreSQL for Docker Compose
POSTGRES_DB=stash
POSTGRES_USER=stash
POSTGRES_PASSWORD=

# Optional media extraction
VIDEO_URL_ANALYSIS_ENABLED=true
VIDEO_URL_MAX_BYTES=18000000
VIDEO_URL_MAX_DURATION_SECONDS=180
VIDEO_URL_DOWNLOAD_FORMAT=bestvideo[ext=mp4][height<=720]+bestaudio[ext=m4a]/best[ext=mp4][height<=720]/best[height<=720]/best
YTDLP_SOCKET_TIMEOUT_SECONDS=15
YTDLP_RETRIES=2
YTDLP_FRAGMENT_RETRIES=2
YTDLP_COOKIES_BROWSER=
YTDLP_COOKIES_FILE=
WHISPER_MODEL=base
WHISPER_MIN_AVAILABLE_MEMORY_BYTES=838860800
STASH_TMP_DIR=/tmp

# Runtime
PORT=8000
RUN_MIGRATIONS_ON_START=false
